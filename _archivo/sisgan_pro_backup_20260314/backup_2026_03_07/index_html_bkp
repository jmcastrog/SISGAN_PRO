        }

        function cerrarModalRapido() { document.getElementById('modal_evento').style.display = 'none'; }

        async function registrarEventoRapido() {
            const ctx = window.modalCtx;
            if (ctx.tipo === 'leche') {
                const peso = document.getElementById('m_peso').value;
                if (!peso) return alert('Ingrese el peso');
                const res = await fetch('/api/registrar-leche', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ numero: ctx.num, nombre: ctx.nom, peso_tobo: peso, peso_tobo_kg: 0.865, turno: ordeñoActual, creado_por: currentUser.user }) });
                if (res.ok) { alert('Pesaje guardado'); cerrarModalRapido(); verFicha(ctx.num); }
            } else {
                const fecha = document.getElementById('m_fecha_p').value;
                const c_num = document.getElementById('m_cria_num').value;
                const c_sexo = document.getElementById('m_cria_sexo').value;
                if (!fecha || !c_num) return alert('Fecha y número de cría obligatorios');
                const res = await fetch('/api/registrar-parto', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ fecha, num_madre: ctx.num, nom_madre: ctx.nom, num_asignado: c_num, sexo_cria: c_sexo, creado_por: currentUser.user }) });
                if (res.ok) { alert('Parto guardado'); cerrarModalRapido(); verFicha(ctx.num); }
            }
        }
    </script>
