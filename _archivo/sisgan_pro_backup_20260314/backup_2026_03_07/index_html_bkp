        // OCR
        function abrirOCR(id) { ocrTarget = id; document.getElementById('modal_ocr').style.display = 'flex'; }
        function cerrarOCR() { document.getElementById('modal_ocr').style.display = 'none'; }
        async function procesarFoto(e) {
            const file = e.target.files[0];
            if (!file) return;
            document.getElementById('ocr_prev').innerHTML = `<img src="${URL.createObjectURL(file)}">`;
            document.getElementById('ocr_loading').style.display = 'block';
            const fd = new FormData(); fd.append('foto', file);
            const res = await fetch('/api/ocr-peso', { method: 'POST', body: fd });
            const data = await res.json();
            document.getElementById('ocr_loading').style.display = 'none';
            if (data.peso_ocr) {
                document.getElementById(ocrTarget).value = data.peso_ocr;
                setTimeout(cerrarOCR, 800);
            }
        }

        // ADMIN (EXCEL FILTER SYSTEM)
        let pendingChanges = {};
        let adminConfig = null;
        let activeFilters = {}; // { colName: [valores seleccionados] }
        let currentFilterCol = null;

        async function cargarTablaAdmin(tabla) {
            try {
                const resConf = await fetch('/api/admin-config');
                if (resConf.ok) {
                    adminConfig = await resConf.json();
                } else {
                    adminConfig = adminConfig || {};
                }
            } catch (e) {
                adminConfig = adminConfig || {};
            }

            pendingChanges = {};
            activeFilters = {}; // Resetear filtros

            // Por petición: Estatus 'Vivos' por defecto para la tabla de animales
            if (tabla === 'animales') {
                activeFilters['estatus'] = ['Vivos'];
            }

            document.getElementById('admin_save_bar').style.display = 'none';
            document.getElementById('admin_sort_box').style.display = (tabla === 'animales') ? 'flex' : 'none';
            let url = `/api/tablas/${tabla}?estatus=Todos`;

            if (tabla === 'animales') {
                const col = document.getElementById('admin_sort_col').value;
                url += `&col=${col}`;
            }


            const res = await fetch(url);
            const { data } = await res.json();
            if (!data || data.length === 0) {
                document.getElementById('admin_body').innerHTML = '<tr><td colspan="100" style="text-align:center; padding:20px;">No hay datos</td></tr>';
                return;
            }

            window.adminDataRaw = data; // Guardar original para filtros
            const allCols = Object.keys(data[0]);
            let visibleCols = adminConfig[tabla] ? adminConfig[tabla].visible : allCols;
            if (!visibleCols) visibleCols = allCols;

            window.adminVisibleCols = visibleCols;

            // Generar Encabezados con iconos de filtro (excepto para nombres y números)
            document.getElementById('admin_th').innerHTML = `
                <tr>
                    <th>Acción</th>
                    ${visibleCols.map(c => {
                const lowCol = c.toLowerCase();
                if (lowCol.includes('nombre') || lowCol.includes('numero') || lowCol.includes('num_')) {
                    return `<th>${c}</th>`;
                }
                // Marcar el icono si hay un filtro activo para esta columna
                const isActive = (activeFilters[c] && activeFilters[c].length > 0 && activeFilters[c].length !== [...new Set(window.adminDataRaw.map(r => String(r[c] || '(Vacío)')))].length) ? 'active' : '';
                return `
                        <th onclick="toggleFiltro(event, '${c}')">
                            ${c} 
                            <i class="fas fa-caret-down filter-icon ${isActive}" id="filter_icon_${c}"></i>
                        </th>`;
            }).join('')}
                </tr>`;

            ejecutarFiltroFinal();
        }

        function renderAdminRows(data, visibleCols, tabla) {
            document.getElementById('admin_body').innerHTML = data.map(row => {
                const pkValue = (tabla === 'animales') ? row.numero : row.id;
                const cells = visibleCols.map(c => {
                    let val = row[c] || '';
                    let displayVal = val;
                    if (typeof val === 'string' && /^\d{4}-\d{2}-\d{2}/.test(val)) {
                        const d = val.split(' ')[0].split('-');
                        displayVal = `${d[2]}-${d[1]}-${d[0]}`;
                    }
                    if (val === '...') displayVal = '';
                    const cellId = `cell_${tabla}_${pkValue}_${c}`;
                    return `<td id="${cellId}" contenteditable="true" style="white-space:nowrap;" oninput="marcarModificado('${cellId}')" onblur="editarCelda('${tabla}', '${pkValue}', '${c}', this.innerText)">${displayVal}</td>`;
                }).join('');

                return `<tr>
                <td style="text-align:center;">
                    <i class="fas fa-trash-alt" style="color:var(--danger); cursor:pointer;" onclick="borrarFilaAdmin('${tabla}', '${pkValue}')"></i>
                </td>
                ${cells}
                </tr>`;
            }).join('');
        }

        // LÓGICA DE FILTROS EXCEL
        function toggleFiltro(event, col) {
            event.stopPropagation();
            const dropdown = document.getElementById('admin_filter_dropdown');

            if (currentFilterCol === col && dropdown.style.display === 'flex') {
                return cerrarFiltroColumna();
            }

            currentFilterCol = col;

            // Obtener valores únicos de los datos originales
            const uniqueVals = [...new Set(window.adminDataRaw.map(r => String(r[col] || '(Vacío)')))].sort();

            const list = document.getElementById('admin_filter_list');
            list.innerHTML = `
                <div style="padding-bottom:10px; border-bottom:1px solid #eee; margin-bottom:10px;">
                    <div class="admin-filter-item" onclick="ordenarLocal('asc')" style="padding:8px; border-radius:4px;">
                        <i class="fas fa-sort-alpha-down"></i> Ordenar de A a Z
                    </div>
                    <div class="admin-filter-item" onclick="ordenarLocal('desc')" style="padding:8px; border-radius:4px;">
                        <i class="fas fa-sort-alpha-up"></i> Ordenar de Z a A
                    </div>
                </div>
                <label class="admin-filter-item">
                    <input type="checkbox" id="filter_select_all" onchange="seleccionarTodosFiltro(this.checked)" ${(!activeFilters[col] || activeFilters[col].length === uniqueVals.length) ? 'checked' : ''}>
                    <span>(Seleccionar todo)</span>
                </label>
                ${uniqueVals.map(v => {
                const isChecked = !activeFilters[col] || activeFilters[col].includes(v);
                return `
                    <label class="admin-filter-item val-item">
                        <input type="checkbox" value="${v}" ${isChecked ? 'checked' : ''}>
                        <span>${v}</span>
                    </label>`;
            }).join('')}
            `;

            // Posicionar el menú
            const rect = event.currentTarget.getBoundingClientRect();
            dropdown.style.left = rect.left + 'px';
            dropdown.style.top = (rect.bottom + window.scrollY) + 'px';
            dropdown.style.display = 'flex';
        }

        function seleccionarTodosFiltro(checked) {
            document.querySelectorAll('#admin_filter_list input').forEach(i => i.checked = checked);
        }

        function filtrarListaValoresUnicos(txt) {
            const query = txt.toLowerCase();
            document.querySelectorAll('.val-item').forEach(el => {
                const val = el.innerText.toLowerCase();
                el.style.display = val.includes(query) ? 'flex' : 'none';
            });
        }

        function cerrarFiltroColumna() {
            document.getElementById('admin_filter_dropdown').style.display = 'none';
        }

        function aplicarFiltroColumna() {
            const checks = document.querySelectorAll('#admin_filter_list .val-item input:checked');
            const selected = Array.from(checks).map(c => c.value);

            activeFilters[currentFilterCol] = selected;

            // Marcar icono como activo
            const icon = document.getElementById(`filter_icon_${currentFilterCol}`);
            icon.classList.toggle('active', selected.length < document.querySelectorAll('#admin_filter_list .val-item input').length);

            ejecutarFiltroFinal();
            cerrarFiltroColumna();
        }

        function ejecutarFiltroFinal() {
            let data = [...window.adminDataRaw];
            const filterCols = Object.keys(activeFilters);

            const filtered = data.filter(row => {
                return filterCols.every(col => {
                    const cellVal = String(row[col] || '(Vacío)');
                    return activeFilters[col].includes(cellVal);
                });
            });

            renderAdminRows(filtered, window.adminVisibleCols, document.getElementById('admin_tablas').value);
        }

        function ordenarLocal(sentido) {
            const tabla = document.getElementById('admin_tablas').value;
            window.adminDataRaw.sort((a, b) => {
                let valA = String(a[currentFilterCol] || '').toLowerCase();
                let valB = String(b[currentFilterCol] || '').toLowerCase();

                // Intento de orden numérico si aplica
                if (!isNaN(valA) && !isNaN(valB) && valA !== '' && valB !== '') {
                    return sentido === 'asc' ? valA - valB : valB - valA;
                }

                if (valA < valB) return sentido === 'asc' ? -1 : 1;
                if (valA > valB) return sentido === 'asc' ? 1 : -1;
                return 0;
            });
            ejecutarFiltroFinal();
            cerrarFiltroColumna();
        }

        // Cerrar al hacer clic fuera
        document.addEventListener('click', (e) => {
            if (!e.target.closest('.admin-filter-dropdown') && !e.target.closest('th')) {
                cerrarFiltroColumna();
            }
        });

        async function abrirConfigAdmin() {
            const tabla = document.getElementById('admin_tablas').value;
            const res = await fetch(`/api/tablas/${tabla}?limit=1`); // Solo para obtener nombres de columnas
            const { data } = await res.json();
            if (!data || data.length === 0) return alert('No hay datos para configurar');

            const allCols = Object.keys(data[0]);
            const config = adminConfig[tabla] || { visible: allCols };

            const list = document.getElementById('admin_config_list');
            list.innerHTML = allCols.map(c => `
                <label style="display:flex; align-items:center; gap:10px; padding:10px; background:#f8fafc; border-radius:6px; cursor:pointer;">
                    <input type="checkbox" value="${c}" ${config.visible.includes(c) ? 'checked' : ''} style="width:18px; height:18px;">
                    <span style="font-weight:600; font-size:14px;">${c}</span>
                </label>
            `).join('');

            document.getElementById('modal_admin_config').style.display = 'flex';
        }

        function cerrarConfigAdmin() {
            document.getElementById('modal_admin_config').style.display = 'none';
        }

        async function guardarConfigAdmin() {
            const tabla = document.getElementById('admin_tablas').value;
            const checks = document.querySelectorAll('#admin_config_list input[type="checkbox"]');
            const visible = [];
            checks.forEach(c => { if (c.checked) visible.push(c.value); });

            if (visible.length === 0) return alert('Debe seleccionar al menos una columna');

            adminConfig[tabla] = { visible, order: visible };

            const res = await fetch('/api/admin-config', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(adminConfig)
            });

            if (res.ok) {
                cerrarConfigAdmin();
                cargarTablaAdmin(tabla);
            }
        }

        function marcarModificado(cellId) {
            const el = document.getElementById(cellId);
            el.style.color = '#f59e0b'; // Naranja (Amber)
            el.style.fontWeight = '700';
            document.getElementById('admin_save_bar').style.display = 'flex';
        }

        function editarCelda(tabla, id, col, val) {
            const key = `${tabla}|${id}|${col}`;
            pendingChanges[key] = val;
        }

        async function guardarCambiosLote() {
            const keys = Object.keys(pendingChanges);
            if (keys.length === 0) return;

            const btn = event.target;
            btn.innerText = 'GUARDANDO...';
            btn.disabled = true;

            try {
                for (const key of keys) {
                    const [tabla, id, columna] = key.split('|');
                    const valor = pendingChanges[key];

                    // VALIDACIÓN: No permitir blanco en numero o nombre para animales
                    if (tabla === 'animales') {
                        if ((columna === 'numero' || columna === 'nombre') && (!valor || valor.trim() === "" || valor === "...")) {
                            alert(`Error: El campo "${columna}" no puede estar vacío.`);
                            return;
                        }
                    }

                    await fetch('/api/save-cell', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ tabla, id, columna, valor })
                    });
                }
                alert('¡Todos los cambios se han guardado con éxito!');
                cargarTablaAdmin(document.getElementById('admin_tablas').value);
            } catch (e) {
                alert('Error al guardar algunos cambios');
                console.error(e);
            } finally {
                btn.innerText = 'GUARDAR TODO';
                btn.disabled = false;
            }
        }

        async function borrarFilaAdmin(tabla, id) {
            if (!confirm(`¿Estás seguro de eliminar este registro de la tabla ${tabla}? Esta acción no se puede deshacer.`)) return;
            const res = await fetch('/api/borrar-fila', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ tabla, id })
            });
            if (res.ok) {
                cargarTablaAdmin(tabla);
            } else {
                alert('Error al eliminar la fila');
            }
        }

        async function agregarFilaAdmin() {
            const tabla = document.getElementById('admin_tablas').value;
            const res = await fetch('/api/agregar-fila', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ tabla }) });
            if (res.ok) { alert('Fila agregada'); cargarTablaAdmin(tabla); }
            else { alert('Error al agregar fila'); }
        }

        // NUEVAS FUNCIONES PARA MODIFICAR Y CONFIRMAR EN LISTAS
        function marcarModificadoGeneral(tabla, id, columna, valor) {
            if (!pendingChanges[id]) pendingChanges[id] = {};
            pendingChanges[id].tabla = tabla;
            pendingChanges[id][columna] = valor;
            document.getElementById('admin_save_bar').style.display = 'flex';
        }

        async function confirmarFila(tabla, id) {
            const rowChanges = [];

            // Si el objeto de cambios no tiene nada para este ID, forzamos el guardado de lo que haya en el DOM si es posible,
            // pero lo más probable es que sea 'animales' de la lista TODO
            if (!pendingChanges[id]) {
                // Si no hay cambios registrados, es posible que el usuario haya editado pero el evento oninput no capturó todo.
                // Sin embargo, las celdas tienen oninput="marcarModificadoGeneral..."
                alert('No hay cambios pendientes para esta fila.');
                return;
            }

            const data = pendingChanges[id];
            for (let col in data) {
                if (col !== 'tabla') {
                    rowChanges.push(fetch('/api/save-cell', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ tabla, id, columna: col, valor: data[col] })
                    }));
                }
            }

            try {
                await Promise.all(rowChanges);
                delete pendingChanges[id];
                if (Object.keys(pendingChanges).length === 0) {
                    document.getElementById('admin_save_bar').style.display = 'none';
                }
                alert('¡Datos confirmados!');
                if (tabla === 'animales' && document.getElementById('sec_fichas').classList.contains('activa')) {
                    cargarTodoAnimales();
                } else {
                    cargarTablaAdmin(tabla);
                }
            } catch (e) {
                alert('Error al guardar: ' + e.message);
            }
        }

        async function generarProximoNumero() {
            const res = await fetch('/api/proximo-numero');
            const data = await res.json();
            if (data.proximo_numero) document.getElementById('n_numero').value = data.proximo_numero;
