            if (res.ok) { alert('Animal creado'); tabFichas('buscar'); cargarDatosBasicos(); }
        }

        function abrirModalRapido(tipo, num, nom) {
            ocrTarget = tipo === 'leche' ? 'm_peso' : null;
            const modal = document.getElementById('modal_evento');
            modal.style.display = 'flex';
            document.getElementById('m_titulo').innerText = tipo === 'parto' ? 'Registrar Parto' : 'Registrar Pesaje';
