            if (q.length < 1) { box.style.display = 'none'; return; }
            const matches = listaAnimales.filter(a => a.numero.includes(q) || a.nombre.toLowerCase().includes(q)).slice(0, 5);
            box.innerHTML = matches.map(m => `<div class="suggestion-item" onclick="selAnimalLeche('${m.numero}', '${m.nombre}')">${m.nombre} (#${m.numero})</div>`).join('');
