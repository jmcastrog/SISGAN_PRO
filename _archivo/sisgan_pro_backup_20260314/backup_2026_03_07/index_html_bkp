        async function guardarNuevoAnimal() {
            const num = document.getElementById('n_numero').value;
            const nom = document.getElementById('n_nombre').value;
            const sexo = document.getElementById('n_sexo').value;
            const tipo = document.getElementById('n_tipo').value;
